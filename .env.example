# Copy this file to .env.local and fill in values for your environment.
# None of these are required for the base MDX-based deployment.
# They are only needed if you extend the project with a headless CMS.

# Contentful (optional)
# CONTENTFUL_SPACE_ID=
# CONTENTFUL_ACCESS_TOKEN=

# Strapi (optional)
# STRAPI_API_URL=
# STRAPI_API_TOKEN=

# Sanity (optional)
# NEXT_PUBLIC_SANITY_PROJECT_ID=
# NEXT_PUBLIC_SANITY_DATASET=
# SANITY_API_TOKEN=
